{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/ask-question",
      "dest": "server.js"
    },
    {
      "src": "/api/generate-script",
      "dest": "server.js"
    },
    {
      "src": "/api/signup",
      "dest": "server.js"
    },
    {
      "src": "/api/signin",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}
